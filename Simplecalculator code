def add(a, b):
    return a + b

def subtract(a, b):
    return a - b

def multiply(a, b):
    return a * b

def divide(a, b):
    if b == 0:
        raise ZeroDivisionError("Cannot divide by zero!")
    return a / b


def calculate(num1, operator, num2):
    if operator == '+':
        return add(num1, num2)
    elif operator == '-':
        return subtract(num1, num2)
    elif operator == '*':
        return multiply(num1, num2)
    elif operator == '/':
        return divide(num1, num2)
    else:
        raise ValueError("Invalid operator!")


def parse_input(user_input):
    parts = user_input.strip().split()

    if len(parts) != 3:
        raise ValueError("Input must be in format: number operator number (e.g., 5 + 3)")

    try:
        num1 = float(parts[0])
        num2 = float(parts[2])
    except ValueError:
        raise ValueError("Invalid numbers!")

    operator = parts[1]

    if operator not in ['+', '-', '*', '/']:
        raise ValueError("Operator must be one of +, -, *, /")

    return num1, operator, num2


def show_menu():
    print("\n--- Command Line Calculator ---")
    print("Enter expression: 5 + 3")
    print("Commands:")
    print("  clear  -> reset")
    print("  exit   -> quit")


def main():
    while True:
        show_menu()
        user_input = input(">>> ").lower()

        if user_input == "exit":
            print("Goodbye!")
            break

        elif user_input == "clear":
            print("Calculator cleared!")
            continue

        try:
            num1, operator, num2 = parse_input(user_input)
            result = calculate(num1, operator, num2)
            print("Result:", result)

        except ZeroDivisionError as zde:
            print("Error:", zde)

        except Exception as e:
            print("Error:", e)


if __name__ == "__main__":
    main()
